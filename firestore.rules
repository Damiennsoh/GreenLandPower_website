rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── USERS (single source of truth for all accounts) ───────────────────
    match /users/{userId} {
      // Anyone can create a user document (signup flow, no Firebase Auth required)
      allow create: if request.resource.data.uid != null;

      // Public read so the admin dashboard (demo login) can show user counts
      allow read: if true;

      // Users can update their own profile; admins can update any
      allow update: if request.auth != null &&
                    (request.auth.uid == userId ||
                     request.auth.token.role == 'admin' ||
                     request.auth.token.role == 'superAdmin');

      // Delete only by SuperAdmin
      allow delete: if request.auth != null &&
                       request.auth.token.role == 'superAdmin';
    }

    // ─── ADMIN SETTINGS ─────────────────────────────────────────────────────
    // Public read/write for demo mode (admin uses sessionStorage, not Firebase Auth)
    match /admin/{document} {
      allow read, write: if true;
    }

    // ─── PUBLIC CONTENT (read by everyone) ──────────────────────────────────
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /portfolio/{portfolioId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /team/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── FORM SUBMISSIONS ────────────────────────────────────────────────────
    // Anyone can submit; admin dashboard can read (demo mode = no Firebase Auth)
    match /submissions/contact/messages/{messageId} {
      allow create: if true;
      allow read, update: if true;
    }

    match /submissions/quotes/requests/{requestId} {
      allow create: if true;
      allow read, update: if true;
    }

    // ─── USER PROFILES (legacy, keep for compatibility) ──────────────────────
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
