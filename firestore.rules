rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - Allow admins to read all, users to read own
    match /users/{userId} {
      // Allow anyone to create their own user account
      allow create: if request.resource.data.uid == userId;
      
      // Allow users to read their own profile, admins to read all
      allow read: if request.auth != null && 
                    (request.auth.uid == userId || 
                     request.auth.token.role == 'admin' || 
                     request.auth.token.role == 'superAdmin');
      
      // Allow users to update their own profile (except role), admins can update any
      allow update: if request.auth != null && 
                    ((request.auth.uid == userId &&
                      request.resource.data.role == resource.data.role) ||
                     request.auth.token.role == 'admin' || 
                     request.auth.token.role == 'superAdmin');
      
      // Allow delete by SuperAdmin only
      allow delete: if request.auth != null && 
                       request.auth.token.role == 'superAdmin';
    }

    // Admin settings - Allow all authenticated users for now
    match /admin/{document} {
      allow read, write: if request.auth != null;
    }

    // Services collection - Everyone can read, authenticated can write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Portfolio collection - Everyone can read, authenticated can write
    match /portfolio/{portfolioId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Team collection - Everyone can read, authenticated can write
    match /team/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contact submissions - Anyone can create, authenticated can read/update
    match /submissions/contact/messages/{messageId} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // Quote requests - Anyone can create, authenticated can read/update
    match /submissions/quotes/requests/{requestId} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // User profiles - Users can manage their own
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
